@echo off
REM ============================================================================
REM  AUTO-FIX for 632 Errors - Oracle NuGet Installation Script
REM  This script automatically installs Oracle.ManagedDataAccess package
REM ============================================================================

setlocal enabledelayedexpansion

set "PROJECT_DIR=C:\Users\asus\Desktop\KumariCinema\KumariCinema"
set "PACKAGES_DIR=%PROJECT_DIR%\packages"

echo.
echo ??????????????????????????????????????????????????????????????????????????
echo ?                    INSTALLING ORACLE CLIENT SUPPORT                   ?
echo ?                      Please wait, this takes 1-2 min...                ?
echo ??????????????????????????????????????????????????????????????????????????
echo.

REM Create packages directory if needed
if not exist "%PACKAGES_DIR%" (
    echo [*] Creating packages directory...
    mkdir "%PACKAGES_DIR%"
)

REM Download Oracle package
echo [1/3] Downloading Oracle.ManagedDataAccess v21.11.0...
powershell -NoProfile -ExecutionPolicy Bypass -Command ^
    "$ProgressPreference = 'SilentlyContinue'; " ^
    "try { " ^
    "  $url = 'https://www.nuget.org/api/v2/package/Oracle.ManagedDataAccess/21.11.0'; " ^
    "  $output = '%PACKAGES_DIR%\Oracle.ManagedDataAccess.21.11.0.nupkg'; " ^
    "  [Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12; " ^
    "  Invoke-WebRequest -Uri $url -OutFile $output -UseBasicParsing; " ^
    "  Write-Host 'Downloaded successfully!'; " ^
    "} catch { " ^
    "  Write-Host 'Download failed: $_'; " ^
    "  exit 1; " ^
    "}"

if errorlevel 1 (
    echo [!] Download failed. Check internet connection.
    goto :ERROR
)

REM Extract NuPkg
echo [2/3] Extracting package contents...
powershell -NoProfile -ExecutionPolicy Bypass -Command ^
    "try { " ^
    "  $nupkg = '%PACKAGES_DIR%\Oracle.ManagedDataAccess.21.11.0.nupkg'; " ^
    "  $extract_dir = '%PACKAGES_DIR%\Oracle.ManagedDataAccess.21.11.0'; " ^
    "  if (!(Test-Path $extract_dir)) { mkdir $extract_dir -Force | Out-Null }; " ^
    "  Add-Type -AssemblyName System.IO.Compression.FileSystem; " ^
    "  [System.IO.Compression.ZipFile]::ExtractToDirectory($nupkg, $extract_dir); " ^
    "  Write-Host 'Extracted successfully!'; " ^
    "} catch { " ^
    "  Write-Host 'Extraction failed: $_'; " ^
    "  exit 1; " ^
    "}"

if errorlevel 1 (
    echo [!] Extraction failed.
    goto :ERROR
)

REM Update packages.config (already done, but verify)
echo [3/3] Verifying packages.config...
powershell -NoProfile -ExecutionPolicy Bypass -Command ^
    "$configFile = '%PROJECT_DIR%\packages.config'; " ^
    "$content = Get-Content $configFile -Raw; " ^
    "if ($content -notlike '*Oracle.ManagedDataAccess*') { " ^
    "  Write-Host '[!] packages.config needs update'; " ^
    "} else { " ^
    "  Write-Host '[?] packages.config already has Oracle entry'; " ^
    "}"

echo.
echo ??????????????????????????????????????????????????????????????????????????
echo ?                        INSTALLATION COMPLETE!                          ?
echo ??????????????????????????????????????????????????????????????????????????
echo.
echo [?] Oracle.ManagedDataAccess installed successfully
echo.
echo NEXT STEPS:
echo  1. Open KumariCinema.sln in Visual Studio
echo  2. Go to: Build > Clean Solution
echo  3. Go to: Build > Build Solution
echo  4. All 632 errors should be gone!
echo.
pause
exit /b 0

:ERROR
echo.
echo ??????????????????????????????????????????????????????????????????????????
echo ?                          INSTALLATION FAILED                           ?
echo ??????????????????????????????????????????????????????????????????????????
echo.
echo Please try the manual installation:
echo  1. Open Visual Studio
echo  2. Tools > NuGet Package Manager > Package Manager Console
echo  3. Run: Install-Package Oracle.ManagedDataAccess -Version 21.11.0
echo.
pause
exit /b 1
